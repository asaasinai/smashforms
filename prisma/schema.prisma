generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReviewStatus {
  DRAFT
  ACTIVE
  SUBMITTED
  COMPLETED
}

model Review {
  id              String       @id @default(cuid())
  targetUrl       String
  title           String?
  vercelProjectId String?
  githubRepo      String?
  repoFileTree    Json?
  devEmail        String?
  status          ReviewStatus @default(DRAFT)
  screenshots     Screenshot[]
  devSpecs        DevSpec[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status])
}

model Screenshot {
  id              String         @id @default(cuid())
  reviewId        String
  review          Review         @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  imageData       String         @db.Text
  notes           String?
  conversation    Json?
  lockedSpec      String?
  order           Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([reviewId])
}

model DevSpec {
  id           String    @id @default(cuid())
  reviewId     String
  review       Review    @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  specMarkdown String
  specJson     Json?
  emailedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([reviewId])
}
