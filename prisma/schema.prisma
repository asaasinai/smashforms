generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReviewStatus {
  DRAFT
  ACTIVE
  SUBMITTED
  COMPLETED
}

enum AnnotationType {
  PIN
  HIGHLIGHT
  DRAW
}

model Review {
  id              String       @id @default(cuid())
  targetUrl       String
  title           String?
  vercelProjectId String?
  githubRepo      String?
  repoFileTree    Json?
  devEmail        String?
  status          ReviewStatus @default(DRAFT)
  annotations     Annotation[]
  devSpecs        DevSpec[]
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([status])
}

model Annotation {
  id              String         @id @default(cuid())
  reviewId        String
  review          Review         @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  type            AnnotationType
  positionX       Float
  positionY       Float
  scrollY         Float          @default(0)
  viewportWidth   Int            @default(1440)
  viewportHeight  Int            @default(900)
  elementSelector String?
  comment         String?
  aiFollowups     Json?
  order           Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([reviewId])
}

model DevSpec {
  id           String    @id @default(cuid())
  reviewId     String
  review       Review    @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  specMarkdown String
  specJson     Json?
  emailedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([reviewId])
}
